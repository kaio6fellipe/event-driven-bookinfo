FROM golang:1.26.2-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/reviews/ ./services/reviews/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/reviews ./services/reviews/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/reviews /bin/reviews
USER 65534:65534
ENTRYPOINT ["/bin/reviews"]
