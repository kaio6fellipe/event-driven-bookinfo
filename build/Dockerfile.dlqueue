FROM golang:1.26.2-alpine@sha256:f85330846cde1e57ca9ec309382da3b8e6ae3ab943d2739500e08c86393a21b1 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/dlqueue/ ./services/dlqueue/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/dlqueue ./services/dlqueue/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/dlqueue /bin/dlqueue
USER 65534:65534
ENTRYPOINT ["/bin/dlqueue"]
