FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/ratings/ ./services/ratings/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/ratings ./services/ratings/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/ratings /bin/ratings
USER 65534:65534
ENTRYPOINT ["/bin/ratings"]
