FROM golang:1.26.2-alpine@sha256:c216c4343b489259302908b67a3c8fa55b283bdc30be729baa38b9953ca28857 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/ratings/ ./services/ratings/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/ratings ./services/ratings/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/ratings /bin/ratings
USER 65534:65534
ENTRYPOINT ["/bin/ratings"]
