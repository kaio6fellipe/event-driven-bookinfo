FROM golang:1.26.2-alpine@sha256:c2a1f7b2095d046ae14b286b18413a05bb82c9bca9b25fe7ff5efef0f0826166 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/dlqueue/ ./services/dlqueue/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/dlqueue ./services/dlqueue/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/dlqueue /bin/dlqueue
USER 65534:65534
ENTRYPOINT ["/bin/dlqueue"]
