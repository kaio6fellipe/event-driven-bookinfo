FROM golang:1.26.2-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY services/details/ ./services/details/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/details ./services/details/cmd/

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /bin/details /bin/details
USER 65534:65534
ENTRYPOINT ["/bin/details"]
